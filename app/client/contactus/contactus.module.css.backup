/* Backup of contactus.module.css before mobile responsive updates */\n\n/* ================= DASHBOARD CANVAS ================= */\n.dashboardCanvas {\n  position: absolute;\n  inset: 0;\n  z-index: 9999;\n  pointer-events: none;\n\n  background-image:\n   url(\"/images/page3_bottom_right_logo.png\"),\n   url(\"/images/page3_bottom_right_logo.png\");\n\n  background-repeat: no-repeat;\n  background-position:\n   top 10px right 15px,\n    bottom -30px right -60px;\n\n  background-size:\n     90px auto,\n    260px auto;\n\n  opacity: 1; \n}\n\n/* ================= DASHBOARD WRAPPER ================= */\n.dashboardWrapper {\n  position: relative;\n  min-height: 100vh;\n\n  padding: 32px 28px 0px 32px;\n\n  display: flex;\n  flex-direction: column;\n}\n.link{\n  text-decoration: none;\n  color: black;\n}\n\n/* ================= CONTACT SECTION ================= */\n\n.contactContainer{\n\n  margin-top:120px;\n\n  display:flex;\n  flex-direction:column;\n\n  align-items:center;\n  justify-content:center;\n\n  text-align:center;\n}\n\n/* ================= LOGO + ADDRESS ================= */\n\n.contactRow{\n\n  display:flex;\n\n  align-items:center;\n\n  gap:10px;\n\n  margin-bottom:30px;\n}\n.contactLogo{\n\n  width:120px;\n}\n\n/* ================= ADDRESS ================= */\n\n.address{\n\n  text-align:left;\n\n  font-family:var(--font-body);\npadding-left: 20px;\n  font-size:23px;\nfont-weight: 500;\n  line-height:1.3;\nborder-left:2px rgb(181, 180, 180) solid ;\n}\n\n/* ================= CONTACT LINE ================= */\n\n.contactLine{\n\n  font-family:var(--font-body);\n\n  font-size:15px;\n  \n  margin-top:10px;\n}\n\n/* ================= DECORATIVE LINE ================= */\n\n.decorLine{\n  margin-top:50px;\n  width:200px;\n}\n\n.linedesign{\n  width:100%;\n  height:100%;\n  /* filter: sepia(1) saturate(0.6) brightness(1.1); */\n}\n\n.line{\npadding-left: 8px;\nmargin-left: 8px;\nborder-left:2px rgb(53, 52, 52) solid ;\n}
